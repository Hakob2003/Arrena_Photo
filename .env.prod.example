# Domain Configuration
DOMAIN=studio.example.com

# Database
DB_USER=studio_admin
DB_PASSWORD=your_secure_db_password
DB_NAME=ai_studio_prod

# Redis
REDIS_PASSWORD=your_secure_redis_password

# JWT Authentication
JWT_SECRET=generate_a_very_long_random_string_here_for_jwt

# MinIO Object Storage
MINIO_USER=minio_admin
MINIO_PASSWORD=your_secure_minio_password

# Grafana Monitoring
GRAFANA_PASSWORD=your_secure_grafana_password

# AI Providers (Optional - can be configured in admin panel)
OPENAI_API_KEY=
STABILITY_API_KEY=
